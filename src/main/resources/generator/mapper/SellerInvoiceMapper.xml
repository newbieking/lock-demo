<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.newbieking.generator.mapper.SellerInvoiceMapper">

    <resultMap id="BaseResultMap" type="com.newbieking.generator.domain.SellerInvoice">
            <id property="id" column="id" />
            <result property="sellerId" column="seller_id" />
            <result property="invoiceNo" column="invoice_no" />
            <result property="amount" column="amount" />
            <result property="status" column="status" />
            <result property="version" column="version" />
            <result property="createTime" column="create_time" />
            <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,seller_id,invoice_no,amount,status,version,
        create_time,update_time
    </sql>
    <!-- 乐观锁更新状态（CAS） -->
    <update id="updateStatus">
        UPDATE seller_invoice
        SET status = #{newStatus}, version = version + 1
        WHERE id = #{invoiceId} AND seller_id = #{sellerId} AND status = #{oldStatus} AND version = #{version}
    </update>
    <select id="selectForUpdate" resultType="com.newbieking.generator.domain.SellerInvoice">
        select *
        from seller_invoice
        where invoice_id = #{invoiceId}
            for update;
    </select>
</mapper>
